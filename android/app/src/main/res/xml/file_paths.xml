<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Downloads directory -->
    <external-path
        name="downloads"
        path="Download/" />
    
    <!-- Cache -->
    <cache-path
        name="cache"
        path="/" />
    
    <!-- External files directory -->
    <external-files-path
        name="external"
        path="." />
    
    <!-- External cache directory -->
    <external-cache-path
        name="external_cache"
        path="." />
    
    <!-- All files in external storage -->
    <root-path
        name="root"
        path="." />
</paths>
